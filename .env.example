# ================================
# F-SRI Environment Variables
# ================================

# Server Configuration
NODE_ENV=development
PORT=3000

# PostgreSQL Database Configuration
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/f_sri_dev"

# Examples for different environments:
# Development: "postgresql://postgres:password@localhost:5432/f_sri_dev"
# Production:  "postgresql://user:password@prod-server:5432/f_sri_prod"
# Docker:      "postgresql://postgres:password@db:5432/f_sri"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here

# Email Configuration (for PDF sending)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# SRI Configuration (Ecuador)
SRI_ENVIRONMENT=test  # 'test' or 'production'
SRI_TIMEOUT=30000

# SSL Certificate Configuration
CERTIFICATE_PASSPHRASE_ENCRYPTION_KEY=your-encryption-key-for-certificates

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Legacy MongoDB (remove after migration)
# MONGO_URI=mongodb://localhost:27017/f-sri

# ================================
# Migration Notes:
# ================================
# 1. This file shows the new PostgreSQL configuration
# 2. Update DATABASE_URL with your PostgreSQL connection details
# 3. Remove MONGO_URI after successful migration
# 4. Run 'npm run setup:postgresql' to initialize the database